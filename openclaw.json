{
    "gateway": {
        "auth": {
            "mode": "token",
            "token": "__GATEWAY_TOKEN__"
        },
        "controlUi": {
            "allowedOrigins": ["http://localhost:18789", "http://127.0.0.1:18789"],
            "allowInsecureAuth": true
        },
        "mode": "local",
        "port": 18789,
        "bind": "auto"
    },
    "agents": {
        "defaults": {
            "workspace": "/root/.openclaw/workspace",
            "instruction": "คุณคือ AI Architect ให้ตอบกระชับ เข้าประเด็นทันที ห้ามเกริ่นนำ และห้ามตอบเป็น JSON ทุกครั้งที่ตอบเสร็จ ให้ปิดท้ายด้วยข้อมูลดังนี้ในบรรทัดใหม่:\n[Model: ชื่อโมเดล]\n[Usage: Input: XXX | Output: YYY tokens]\n*หมายเหตุ: หากเป็นรุ่นฟรีให้ระบุ (Free) ไว้หลังชื่อโมเดล",
            "model": {
                "primary": "google/gemini-3-flash-preview",
                "fallbacks": ["ollama/llama3.1:8b-instruct-q5_K_M"]
            },
            "models": {
                "google/gemini-3-flash-preview": { "alias": "Gemini Flash" },
                "google/gemini-1.5-pro": { "alias": "Gemini Pro" },
                "google/gemini-1.5-flash": { "alias": "Gemini 1.5 Flash" },
                "ollama/llama3.1:8b-instruct-q5_K_M": { "alias": "Llama 3.1 8B (Speed)" }
            }
        }
    },
    "models": {
        "providers": {
            "ollama": {
                "baseUrl": "http://ollama:11434",
                "api": "ollama",
                "models": [{ "id": "llama3.1:8b-instruct-q5_K_M", "name": "Llama 3.1 8B (Speed)" }]
            },
            "google": {
                "baseUrl": "https://generativelanguage.googleapis.com",
                "apiKey": "__GOOGLE_API_KEY__",
                "models": [
                    { "id": "gemini-3-flash-preview", "name": "Gemini 3 Flash Preview" },
                    { "id": "gemini-1.5-pro", "name": "Gemini 1.5 Pro" },
                    { "id": "gemini-1.5-flash", "name": "Gemini 1.5 Flash" }
                ]
            }
        }
    },
    "channels": {
        "telegram": {
            "enabled": true,
            "botToken": "__TELEGRAM_TOKEN__"
        }
    }
}
