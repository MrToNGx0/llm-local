{
    "gateway": {
        "auth": {
            "mode": "token",
            "token": "__GATEWAY_TOKEN__"
        },
        "controlUi": {
            "allowedOrigins": ["http://localhost:18789", "http://127.0.0.1:18789"],
            "allowInsecureAuth": true
        },
        "mode": "local",
        "port": 18789,
        "bind": "auto"
    },
    "agents": {
        "defaults": {
            "workspace": "/root/.openclaw/workspace",
            "model": {
                "primary": { "id": "google/gemini-3-flash-preview" },
                "secondary": { "id": "ollama/llama3.1:8b-instruct-q4_K_M" }
            }
        }
    },
    "models": {
        "providers": {
            "ollama": {
                "baseUrl": "http://ollama:11434",
                "api": "ollama",
                "models": [
                    { "id": "llama3.1:8b-instruct-q4_K_M" }
                ]
            },
            "google": {
                "baseUrl": "https://generativelanguage.googleapis.com",
                "apiKey": "__GOOGLE_API_KEY__",
                "models": [
                    { "id": "gemini-3-flash-preview" },
                    { "id": "gemini-1.5-pro" },
                    { "id": "gemini-1.5-flash" }
                ]
            }
        }
    },
    "channels": {
        "telegram": {
            "enabled": true,
            "botToken": "__TELEGRAM_TOKEN__"
        }
    }
}
