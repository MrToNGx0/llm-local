{
    "gateway": {
        "auth": {
            "mode": "token",
            "token": "REPLACE_GATEWAY_TOKEN"
        },
        "controlUi": {
            "allowedOrigins": ["http://localhost:18789", "http://127.0.0.1:18789"],
            "allowInsecureAuth": true
        },
        "mode": "local",
        "port": 18789,
        "bind": "auto"
    },
    "agents": {
        "defaults": {
            "workspace": "/root/.openclaw/workspace",
            "model": { "primary": "ollama/REPLACE_MODEL" }
        }
    },
    "models": {
        "providers": {
            "ollama": {
                "baseUrl": "http://ollama:11434",
                "api": "ollama",
                "models": []
            },
            "google": {
                "baseUrl": "https://generativelanguage.googleapis.com",
                "apiKey": "REPLACE_GOOGLE_KEY",
                "models": []
            }
        }
    },
    "channels": {
        "telegram": {
            "enabled": true,
            "botToken": "REPLACE_TELEGRAM_TOKEN"
        }
    }
}
