# =================================================================
# OpenClaw + Ollama Deployment Configuration (Example)
# =================================================================

# --- Server Ports ---
# พอร์ตสำหรับเข้าใช้งานผ่าน Browser
OLLAMA_PORT=11434
OPENCLAW_PORT=18789
DOZZLE_PORT=8888

# --- AI Model Config ---
# ชื่อ Model ที่ต้องการใช้ (ต้องมีอยู่ใน Ollama หรือสั่ง Pull มาก่อน)
# ตัวอย่าง: llama3.1:8b-instruct-q5_K_M, qwen2.5:7b-instruct
MODEL=llama3.1:8b-instruct-q5_K_M

# --- OpenClaw Security ---
# รหัสผ่าน (Token) สำหรับเข้าหน้า Web UI ครั้งแรก
# แนะนำให้ใช้รหัสนิรภัยแบบยาว หรือ UUID
GATEWAY_TOKEN=your_secure_gateway_token_here

# --- External API Keys (Optional) ---
# ใส่ API Key หากต้องการใช้ Model ภายนอกนอกเหนือจาก Ollama
GOOGLE_API_KEY=your_google_ai_studio_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here

# --- Telegram Bot Config ---
# ใส่ Token ที่ได้จาก @BotFather เพื่อเปิดใช้งานบอท Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here

# --- Connection Settings ---
# โดยปกติจะใช้ชื่อ Service ใน Docker (ollama)
OLLAMA_BASE_URL=http://ollama:11434