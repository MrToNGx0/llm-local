# --- Server Ports ---
OLLAMA_PORT=11434
OPENCLAW_PORT=8080
DOZZLE_PORT=8888

# --- Model Config ---
# Local Model (Ollama)
MODEL=llama3.1:8b-instruct-q5_K_M

# --- External APIs (Required for Routing) ---
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Open Claw Security ---
# Set to 'true' to enable login if you expose this to the internet
ENABLE_AUTH=false
ADMIN_PASSWORD=change_this_password

# --- Telegram Bot (Optional) ---
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
